# NASA Open APIs — https://api.nasa.gov/ (DEMO_KEY works with rate limits)
NASA_API_KEY=

# OpenWeather — https://openweathermap.org/api (optional; enables live city readings)
OPENWEATHER_API_KEY=

# NOAA Climate Data Online — https://www.ncei.noaa.gov/cdo-web/token
# Enables live global temperature series in the Story section (NOAA NCEI)
NOAA_CDO_TOKEN=
